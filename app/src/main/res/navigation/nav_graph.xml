<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/welcomeFragment">

    <!-- Welcome Screen -->
    <fragment
        android:id="@+id/welcomeFragment"
        android:name="za.co.varsitycollege.serversamurai.flexforce.Welcome_Screen_Fragement"
        android:label="Welcome"
        tools:layout="@layout/fragment_welcome__screen__fragement">
        <action
            android:id="@+id/action_welcomeFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_welcomeFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <!-- Login Screen -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="za.co.varsitycollege.serversamurai.flexforce.Login_Screen"
        android:label="Login"
        tools:layout="@layout/fragment_login__screen">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <!-- Register Screen -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="za.co.varsitycollege.serversamurai.flexforce.Register_Screen"
        android:label="Register"
        tools:layout="@layout/fragment_register__screen">
        <action
            android:id="@+id/action_registerFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <!-- Home Screen (After Login/Register) -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="za.co.varsitycollege.serversamurai.flexforce.Home_Screen"
        android:label="Home"
        tools:layout="@layout/fragment_home__screen" />
</navigation>